# ══════════════════════════════════════════════
# Portfolio — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
#
# In development: the contact form works without any keys
# (emails are logged to console instead of sent).
#
# In production: RESEND_API_KEY is required for email delivery.
# ══════════════════════════════════════════════

# ── Resend (Email Delivery) ──
# Get your API key at https://resend.com
# Required in production. Optional in development (form still works without it).
RESEND_API_KEY=

# The "from" address for outgoing emails.
# Must be a verified domain in Resend, or use the default onboarding address.
# Default: "Portfolio <onboarding@resend.dev>"
RESEND_FROM_EMAIL=

# ── Contact Recipient ──
# The email address where contact form submissions are delivered.
# Default: ibrahimhuseein842@gmail.com
CONTACT_EMAIL=
